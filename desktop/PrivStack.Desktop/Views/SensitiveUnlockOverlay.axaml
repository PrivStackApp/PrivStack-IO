<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PrivStack.Desktop.ViewModels"
             x:Class="PrivStack.Desktop.Views.SensitiveUnlockOverlay"
             x:DataType="vm:SensitiveUnlockViewModel">

    <!-- Semi-transparent dark overlay that covers the entire sensitive view -->
    <Panel>
        <Border Classes="modal-backdrop"/>
        <Border Background="{DynamicResource ThemeSurfaceBrush}"
                CornerRadius="12" Padding="32"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="400"
                Classes="modal">
            <StackPanel Spacing="16">
                <!-- Lock Icon -->
                <Border Background="{DynamicResource ThemeHoverBrush}"
                        CornerRadius="50" Width="80" Height="80"
                        HorizontalAlignment="Center">
                    <PathIcon Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"
                               Width="48" Height="48"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                </Border>

                <!-- Title -->
                <TextBlock Text="Sensitive Data Locked"
                           FontSize="{DynamicResource ThemeFontSizeXl}" FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>

                <!-- Description -->
                <Panel>
                    <TextBlock Text="Enter your master password to view this content"
                               Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                               TextAlignment="Center" TextWrapping="Wrap"
                               IsVisible="{Binding !IsBiometricAvailable}"/>
                    <TextBlock Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                               TextAlignment="Center" TextWrapping="Wrap"
                               IsVisible="{Binding IsBiometricAvailable}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Enter your password or use {0}">
                                <Binding Path="BiometricDisplayName"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Panel>

                <!-- Biometric Button -->
                <Button x:Name="BiometricButton"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding AttemptBiometricUnlockCommand}"
                        IsEnabled="{Binding !IsBiometricAuthenticating}"
                        IsVisible="{Binding IsBiometricAvailable}"
                        Background="{DynamicResource ThemeSurfaceElevatedBrush}"
                        Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                        Padding="12,10" CornerRadius="6">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <PathIcon Data="M17.81 4.47c-.08 0-.16-.02-.23-.06C15.66 3.42 14 3 12.01 3c-1.98 0-3.86.47-5.57 1.41-.24.13-.54.04-.68-.2-.13-.24-.04-.55.2-.68C7.82 2.52 9.86 2 12.01 2c2.13 0 3.99.47 6.03 1.52.25.13.34.43.21.67-.09.18-.26.28-.44.28zM3.5 9.72a.499.499 0 01-.25-.93C5.55 7.15 8.57 5.87 12 5.87c3.41 0 6.74 1.44 8.76 3.07.22.18.25.51.07.73-.18.22-.51.25-.73.07-1.82-1.47-4.96-2.87-8.1-2.87-3.14 0-6.04 1.2-8.25 2.78-.08.05-.16.07-.25.07zm15.02 4.01c-.12 0-.24-.05-.33-.14-.84-.93-1.81-1.62-2.88-2.04-.3-.12-.45-.46-.33-.76.12-.3.46-.45.76-.33 1.22.48 2.33 1.26 3.27 2.33a.5.5 0 01-.49.94zm-3.47 4.69c-.14 0-.27-.06-.37-.17-.55-.6-1.27-.97-2.13-1.09a.513.513 0 01-.44-.56c.04-.28.29-.48.56-.44 1.08.15 2 .63 2.73 1.41a.5.5 0 01-.35.85zM12 16c-.72 0-1.3.58-1.3 1.3 0 .72.58 1.3 1.3 1.3.72 0 1.3-.58 1.3-1.3 0-.72-.58-1.3-1.3-1.3z"
                                   Width="16" Height="16"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                        <TextBlock IsVisible="{Binding !IsBiometricAuthenticating}" FontWeight="SemiBold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Use {0}">
                                    <Binding Path="BiometricDisplayName"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text="Authenticating..." IsVisible="{Binding IsBiometricAuthenticating}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <!-- "or" separator when biometric available -->
                <Grid ColumnDefinitions="*,Auto,*" IsVisible="{Binding IsBiometricAvailable}">
                    <Border Grid.Column="0" Height="1" Background="{DynamicResource ThemeBorderSubtleBrush}"
                            VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="or enter password"
                               FontSize="{DynamicResource ThemeFontSizeXsSm}"
                               Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                    <Border Grid.Column="2" Height="1" Background="{DynamicResource ThemeBorderSubtleBrush}"
                            VerticalAlignment="Center" Margin="8,0,0,0"/>
                </Grid>

                <!-- Password Input -->
                <TextBox x:Name="PasswordInput"
                         PasswordChar="*"
                         Watermark="Master Password"
                         Text="{Binding Password, Mode=TwoWay}"
                         IsEnabled="{Binding !IsUnlocking}"
                         Classes="themed-input"
                         Padding="12">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding UnlockCommand}"/>
                    </TextBox.KeyBindings>
                </TextBox>

                <!-- Error Message -->
                <Border Background="{DynamicResource ThemeDangerMutedBrush}" CornerRadius="6" Padding="12,8"
                        IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource ThemeDangerBrush}"
                               TextAlignment="Center"
                               FontSize="{DynamicResource ThemeFontSizeSmMd}"/>
                </Border>

                <!-- Unlock Button -->
                <Button HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding UnlockCommand}"
                        IsEnabled="{Binding !IsUnlocking}"
                        Background="{DynamicResource ThemePrimaryBrush}"
                        Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                        Padding="12,10"
                        CornerRadius="6"
                        FontWeight="SemiBold">
                    <Panel>
                        <TextBlock Text="Unlock" IsVisible="{Binding !IsUnlocking}"/>
                        <TextBlock Text="Unlocking..." IsVisible="{Binding IsUnlocking}"/>
                    </Panel>
                </Button>

                <!-- Hint text -->
                <TextBlock Text="Your data is protected with end-to-end encryption"
                           FontSize="{DynamicResource ThemeFontSizeXsSm}"
                           Foreground="{DynamicResource ThemeTextMutedBrush}"
                           TextAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Panel>
</UserControl>
