<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:PrivStack.Desktop.Views"
        xmlns:tray="using:PrivStack.Desktop.ViewModels.AiTray"
        xmlns:app="using:PrivStack.Desktop"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="600"
        x:Class="PrivStack.Desktop.Views.AiTrayWindow"
        x:DataType="tray:AiSuggestionTrayViewModel"
        Title="{x:Static app:AiPersona.Name}"
        Width="420" Height="600"
        MinWidth="320" MinHeight="400"
        CanResize="True"
        SystemDecorations="Full"
        Background="{DynamicResource ThemeSurfaceBrush}"
        Icon="avares://PrivStack.Desktop/Assets/privstack-logo.png">

    <Window.Styles>
        <Style Selector="Window > ContentPresenter">
            <Setter Property="Margin" Value="8,0,8,8"/>
        </Style>
    </Window.Styles>

    <!-- The AiSuggestionTray UserControl is set as Content programmatically -->

</Window>
