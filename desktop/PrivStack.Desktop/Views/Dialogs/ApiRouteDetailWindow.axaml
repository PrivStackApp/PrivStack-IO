<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PrivStack.Desktop.Views.Dialogs.ApiRouteDetailWindow"
        Title="Endpoint Detail"
        Width="560" Height="520"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        SystemDecorations="Full"
        Background="{DynamicResource ThemeSurfaceBrush}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header: METHOD /path -->
        <Border Grid.Row="0" Padding="24,20,24,16"
                BorderBrush="{DynamicResource ThemeBorderSubtleBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border x:Name="MethodBadge" CornerRadius="4" Padding="8,4">
                        <TextBlock x:Name="MethodText"
                                   FontFamily="Consolas, Menlo, monospace"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="White"/>
                    </Border>
                    <TextBlock x:Name="PathText"
                               FontFamily="Consolas, Menlo, monospace"
                               FontSize="14" VerticalAlignment="Center"
                               Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                </StackPanel>
                <TextBlock x:Name="DescriptionText"
                           FontSize="{DynamicResource ThemeFontSizeSm}"
                           Foreground="{DynamicResource ThemeTextMutedBrush}"/>
            </StackPanel>
        </Border>

        <!-- Scrollable body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16,24,0">
            <StackPanel x:Name="DetailContent" Spacing="20"/>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ThemeBorderSubtleBrush}"
                Padding="24,14">
            <Button Content="Close" Click="OnClose"
                    HorizontalAlignment="Right"
                    Background="{DynamicResource ThemeSurfaceElevatedBrush}"
                    Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                    Padding="20,10" CornerRadius="6"/>
        </Border>
    </Grid>
</Window>
