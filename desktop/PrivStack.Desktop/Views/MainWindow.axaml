<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PrivStack.Desktop.ViewModels"
        xmlns:views="using:PrivStack.Desktop.Views"
        xmlns:controls="using:PrivStack.Desktop.Controls"
        xmlns:plugin="using:PrivStack.Desktop.Services.Plugin"
        xmlns:services="using:PrivStack.Desktop.Services"
        xmlns:emoji="using:PrivStack.UI.Adaptive.Controls.EmojiPicker"
        xmlns:toast="using:PrivStack.Desktop.Views.Controls"
        xmlns:models="using:PrivStack.Services.Models"
        xmlns:app="using:PrivStack.Desktop"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="PrivStack.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="avares://PrivStack.Desktop/Assets/privstack-logo.png"
        Title="{Binding WindowTitle}"
        Width="1000" Height="700"
        MinWidth="800" MinHeight="500"
        Background="{DynamicResource ThemeBackgroundBrush}"
        FontFamily="{DynamicResource ThemeFontSans}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="28">

    <Window.Styles>
        <!-- Timer pulse animation -->
        <Style Selector="Border.timer-pulse">
            <Style.Animations>
                <Animation Duration="0:0:1.5" IterationCount="INFINITE">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Opacity" Value="0.3"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Sidebar width transitions -->
        <Style Selector="views|NavigationSidebar">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.15" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="views|NavigationSidebar.collapsed">
            <Setter Property="Width" Value="56"/>
        </Style>

        <!-- AI persona speech balloon fade -->
        <Style Selector="Border#AiBalloon">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform" Value="translate(0px, 8px)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border#AiBalloon.balloon-visible">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="RenderTransform" Value="translate(0px, 0px)"/>
        </Style>

        <!-- AI Tray slide drawer animation -->
        <Style Selector="StackPanel#AiTrayDrawer">
            <Setter Property="RenderTransform" Value="translate(420px, 0px)"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" Easing="CubicEaseOut"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="StackPanel#AiTrayDrawer.open">
            <Setter Property="RenderTransform" Value="translate(0px, 0px)"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
        </Style>
        <Style Selector="StackPanel#AiTrayDrawer.half-height">
            <Setter Property="VerticalAlignment" Value="Bottom"/>
        </Style>
        <Style Selector="StackPanel#AiTrayDrawer.half-height Border#AiTrayBorderContainer">
            <Setter Property="CornerRadius" Value="8,0,0,0"/>
        </Style>

        <!-- Info panel slide drawer animation -->
        <Style Selector="StackPanel#InfoPanelDrawer">
            <Setter Property="RenderTransform" Value="translate(700px, 0px)"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" Easing="CubicEaseOut"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="StackPanel#InfoPanelDrawer.open">
            <Setter Property="RenderTransform" Value="translate(0px, 0px)"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Panel>
        <!-- Main layout: DockPanel ensures status bar is docked to bottom first, remaining space fills content -->
        <DockPanel>
            <!-- Title bar drag region / spacer for macOS traffic lights -->
            <Border DockPanel.Dock="Top" x:Name="TitleBarSpacer"
                    Background="{DynamicResource ThemeBackgroundBrush}"
                    Height="28"
                    IsHitTestVisible="False"/>

            <!-- License expiration banner -->
            <Border DockPanel.Dock="Top"
                    IsVisible="{Binding IsLicenseExpiredBannerVisible}"
                    Background="{DynamicResource ThemeDangerBrush}" Padding="8,6"
                    HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Your trial has expired. Your data is safe but the app is now read-only."
                               Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="{DynamicResource ThemeFontSizeSmMd}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Subscribe or Purchase"
                            Command="{Binding OpenPricingPageCommand}"
                            Foreground="{DynamicResource ThemeTextPrimaryBrush}" Background="Transparent"
                            BorderBrush="{DynamicResource ThemeTextPrimaryBrush}" BorderThickness="1" Padding="12,4" FontSize="{DynamicResource ThemeFontSizeSm}"
                            Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Status Bar: docked to bottom BEFORE content so DockPanel subtracts it first -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource ThemeBackgroundBrush}"
                    BorderBrush="{DynamicResource ThemeBorderSubtleBrush}"
                    BorderThickness="0,1,0,0"
                    BoxShadow="0 -1 4 0 #0A000000"
                    Padding="16,6"
                    IsVisible="{Binding !IsFocusMode}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- Left side: Status message -->
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource ThemeTextMutedBrush}"
                               FontSize="{DynamicResource ThemeFontSizeXsSm}"
                               VerticalAlignment="Center"/>

                    <!-- Center: Active Timer Indicator -->
                    <Border Grid.Column="1"
                            IsVisible="{Binding HasActiveTimers}"
                            Background="{DynamicResource ThemePrimaryMutedBrush}"
                            CornerRadius="{DynamicResource ThemeRadiusSm}"
                            Padding="10,3"
                            Margin="16,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <!-- Pulsing dot: green when running -->
                            <Border Classes="timer-pulse"
                                    Width="7" Height="7" CornerRadius="4"
                                    Background="{DynamicResource ThemeSuccessBrush}"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding IsTaskTimerRunning}"/>
                            <!-- Static dot: yellow when paused -->
                            <Border Width="7" Height="7" CornerRadius="4"
                                    Background="{DynamicResource ThemeWarningBrush}"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding IsTaskTimerPaused}"/>

                            <!-- Task title (clickable to navigate) -->
                            <Button Command="{Binding NavigateToTimedTaskCommand}"
                                    Background="Transparent" Padding="0" Margin="0"
                                    Cursor="Hand" VerticalAlignment="Center"
                                    BorderThickness="0" MinHeight="0" MinWidth="0">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </Button.Styles>
                                <TextBlock Text="{Binding TimedTaskTitle}"
                                           FontSize="{DynamicResource ThemeFontSizeXsSm}"
                                           Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                           MaxWidth="200" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </Button>

                            <!-- Elapsed time -->
                            <TextBlock Text="{Binding TaskTimerDisplay}"
                                       FontSize="{DynamicResource ThemeFontSizeXsSm}"
                                       FontWeight="SemiBold"
                                       FontFamily="{DynamicResource ThemeFontMono}"
                                       Foreground="{DynamicResource ThemePrimaryBrush}"
                                       VerticalAlignment="Center"/>

                            <!-- Multi-timer count badge -->
                            <Border IsVisible="{Binding HasMultipleTimers}"
                                    Background="{DynamicResource ThemeSecondaryMutedBrush}"
                                    CornerRadius="{DynamicResource ThemeRadiusXs}"
                                    Padding="5,1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AdditionalTimerText}"
                                           FontSize="{DynamicResource ThemeFontSizeXs}"
                                           Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- Separator -->
                            <Border Width="1" Height="12"
                                    Background="{DynamicResource ThemeBorderSubtleBrush}"
                                    VerticalAlignment="Center" Margin="2,0"/>

                            <!-- Pause button (visible when running) -->
                            <Button Command="{Binding PauseTaskTimerCommand}"
                                    IsVisible="{Binding IsTaskTimerRunning}"
                                    Background="Transparent" Padding="3,1" Margin="0"
                                    BorderThickness="0" MinHeight="0" MinWidth="0"
                                    Cursor="Hand" ToolTip.Tip="Pause timer"
                                    VerticalAlignment="Center">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="{DynamicResource ThemeHoverBrush}"/>
                                    </Style>
                                </Button.Styles>
                                <PathIcon Data="M6 19h4V5H6v14zm8-14v14h4V5h-4z"
                                         Width="10" Height="10"
                                         Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                            </Button>

                            <!-- Resume button (visible when paused) -->
                            <Button Command="{Binding ResumeTaskTimerCommand}"
                                    IsVisible="{Binding IsTaskTimerPaused}"
                                    Background="Transparent" Padding="3,1" Margin="0"
                                    BorderThickness="0" MinHeight="0" MinWidth="0"
                                    Cursor="Hand" ToolTip.Tip="Resume timer"
                                    VerticalAlignment="Center">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="{DynamicResource ThemeHoverBrush}"/>
                                    </Style>
                                </Button.Styles>
                                <PathIcon Data="M8 5v14l11-7z"
                                         Width="10" Height="10"
                                         Foreground="{DynamicResource ThemeSuccessBrush}"/>
                            </Button>

                            <!-- Stop button -->
                            <Button Command="{Binding StopTaskTimerCommand}"
                                    Background="Transparent" Padding="3,1" Margin="0"
                                    BorderThickness="0" MinHeight="0" MinWidth="0"
                                    Cursor="Hand" ToolTip.Tip="Stop timer"
                                    VerticalAlignment="Center">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="{DynamicResource ThemeHoverBrush}"/>
                                    </Style>
                                </Button.Styles>
                                <PathIcon Data="M6 6h12v12H6z"
                                         Width="10" Height="10"
                                         Foreground="{DynamicResource ThemeDangerBrush}"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Right side: Intent Tray + Update status + Subscription + Storage -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16">
                        <!-- AI Persona Button -->
                        <Button Command="{Binding ToggleAiTrayCommand}"
                                IsVisible="{Binding AiTrayVM.IsEnabled}"
                                Background="Transparent" BorderThickness="0"
                                Padding="0" Margin="0"
                                MinHeight="0" MinWidth="0"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                ToolTip.Tip="{x:Static app:AiPersona.Name}">
                            <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </Button.Styles>
                            <PathIcon x:Name="AiStarIcon"
                                     Data="M12,0 L14.5,9.5 L24,12 L14.5,14.5 L12,24 L9.5,14.5 L0,12 L9.5,9.5 Z"
                                     Width="14" Height="14"
                                     Foreground="{Binding AiTrayVM.HasUnseenInsight, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFD700|ThemePrimary'}"/>
                        </Button>

                        <!-- Update Status Indicator -->
                        <Button Command="{Binding UpdateVM.StatusBarClickCommand}"
                                Background="Transparent" BorderThickness="0"
                                Padding="0" Margin="0"
                                MinHeight="0" MinWidth="0"
                                Cursor="Hand"
                                VerticalAlignment="Center">
                            <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </Button.Styles>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <!-- Green dot when update is available -->
                                <Border Width="6" Height="6" CornerRadius="3"
                                        Background="{DynamicResource ThemeSuccessBrush}"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding UpdateVM.IsStatusBarHighlighted}"/>
                                <TextBlock Text="{Binding UpdateVM.StatusBarText}"
                                           FontSize="{DynamicResource ThemeFontSizeXsSm}"
                                           VerticalAlignment="Center">
                                    <TextBlock.Styles>
                                        <Style Selector="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryBrush}"/>
                                        </Style>
                                    </TextBlock.Styles>
                                </TextBlock>
                            </StackPanel>
                        </Button>

                        <!-- Subscription Badge -->
                        <Button IsVisible="{Binding SubscriptionBadgeVM.IsBadgeVisible}"
                                Command="{Binding SubscriptionBadgeVM.OpenModalCommand}"
                                Background="{DynamicResource ThemePrimaryMutedBrush}"
                                BorderThickness="0"
                                CornerRadius="{DynamicResource ThemeRadiusSm}"
                                Padding="8,3"
                                VerticalContentAlignment="Center"
                                Cursor="Hand"
                                MinHeight="0" MinWidth="0"
                                VerticalAlignment="Center">
                            <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="{DynamicResource ThemeHoverBrush}"/>
                                </Style>
                            </Button.Styles>
                            <TextBlock Text="{Binding SubscriptionBadgeVM.BadgeText}"
                                       FontSize="{DynamicResource ThemeFontSizeXs}"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource ThemePrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Button>

                        <!-- Storage State Pill -->
                        <TextBlock Text="{Binding StorageStatePillVM.PillText}"
                                   Foreground="{Binding StorageStatePillVM.PillColor}"
                                   FontSize="{DynamicResource ThemeFontSizeXs}"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Sidebar + Content area (fill child — takes all remaining space after docked items) -->
            <Grid ColumnDefinitions="Auto,*">
                <!-- Navigation Sidebar -->
                <views:NavigationSidebar Grid.Column="0"
                                         Classes.collapsed="{Binding IsSidebarCollapsed}"
                                         IsVisible="{Binding !IsFocusMode}"
                                         DataContext="{Binding}"/>

                <!-- Content Area -->
                <Panel Grid.Column="1" ClipToBounds="True">
                    <!-- Main Content Area + Info Panel overlay -->
                        <ContentControl Content="{Binding CurrentViewModel}" ClipToBounds="True"/>

                        <!-- Toast Notification Container (centered on plugin content area) -->
                        <toast:ToastContainer ZIndex="1100"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Top"
                                              Margin="0,8,0,0"
                                              IsHitTestVisible="True"/>

                        <!-- Info Panel: Collapsed side tab (visible when panel is closed and not on Graph/Nexus) -->
                        <!-- Hover region: wider hit-test area that fades in the tab button -->
                        <Border Classes="info-tab-hover-zone"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                IsVisible="{Binding ShowInfoPanelTab}"
                                ZIndex="10">
                            <Border.Styles>
                                <Style Selector="Border.info-tab-hover-zone Button">
                                    <Setter Property="Opacity" Value="0.15"/>
                                    <Setter Property="Transitions">
                                        <Transitions>
                                            <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                                        </Transitions>
                                    </Setter>
                                </Style>
                                <Style Selector="Border.info-tab-hover-zone Button:pointerover">
                                    <Setter Property="Opacity" Value="1"/>
                                </Style>
                            </Border.Styles>
                        <Button Command="{Binding ToggleInfoPanelCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="{DynamicResource ThemeSurfaceBrush}"
                                BorderBrush="{DynamicResource ThemeBorderBrush}"
                                BorderThickness="1,1,0,1"
                                CornerRadius="6,0,0,6"
                                Padding="5,16"
                                Cursor="Hand">
                            <Button.Styles>
                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="{DynamicResource ThemeHoverBrush}"/>
                                </Style>
                            </Button.Styles>
                            <StackPanel Spacing="16" VerticalAlignment="Center">
                                <LayoutTransformControl>
                                    <LayoutTransformControl.LayoutTransform>
                                        <RotateTransform Angle="-90"/>
                                    </LayoutTransformControl.LayoutTransform>
                                    <TextBlock Text="Info"
                                               FontSize="{DynamicResource ThemeFontSizeXsSm}"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                </LayoutTransformControl>
                                <Border Width="3" Height="3" CornerRadius="2"
                                        Background="{DynamicResource ThemeTextMutedBrush}"
                                        Opacity="0.4"
                                        HorizontalAlignment="Center"
                                        IsVisible="{Binding InfoPanelVM.ShowGraphTab}"/>
                                <LayoutTransformControl IsVisible="{Binding InfoPanelVM.ShowGraphTab}">
                                    <LayoutTransformControl.LayoutTransform>
                                        <RotateTransform Angle="-90"/>
                                    </LayoutTransformControl.LayoutTransform>
                                    <TextBlock Text="Graph"
                                               FontSize="{DynamicResource ThemeFontSizeXsSm}"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                </LayoutTransformControl>
                            </StackPanel>
                        </Button>
                        </Border>

                        <!-- AI Tray stays open until explicitly closed (close button or Escape) -->

                        <!-- AI Suggestion Tray: Slide Drawer (right-side panel) -->
                        <StackPanel x:Name="AiTrayDrawer"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Stretch"
                                    MaxHeight="{Binding AiTrayMaxHeight}"
                                    Margin="0,0,0,0"
                                    ZIndex="12"
                                    IsVisible="{Binding AiTrayVM.IsEnabled}"
                                    Classes.open="{Binding IsAiTrayDrawerOpen}"
                                    Classes.half-height="{Binding IsAiTrayAttachedHalf}">

                            <!-- Drag handle: hidden in half-height mode (height is constrained) -->
                            <Border x:Name="AiTrayDragHandle"
                                    Width="10"
                                    Cursor="SizeWestEast"
                                    Background="Transparent"
                                    Margin="-3,0,-3,0"
                                    ZIndex="5"
                                    IsVisible="{Binding IsAiTrayAttachedFull}">
                                <Border Width="4" Height="40"
                                        CornerRadius="2"
                                        Background="{DynamicResource ThemeBorderBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Opacity="0.5">
                                    <Border.Styles>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="Opacity" Value="0.9"/>
                                        </Style>
                                    </Border.Styles>
                                </Border>
                            </Border>

                            <Border x:Name="AiTrayBorderContainer"
                                    CornerRadius="8,0,0,8"
                                    Background="{DynamicResource ThemeSurfaceBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    BorderThickness="1,1,0,1"
                                    BoxShadow="-3 0 12 0 #30000000, -8 0 32 0 #18000000"
                                    Width="{Binding AiTrayWidth}"
                                    ClipToBounds="True">
                                <Grid RowDefinitions="Auto,*">
                                    <!-- Header -->
                                    <Border Grid.Row="0" Padding="12,8"
                                            BorderBrush="{DynamicResource ThemeBorderSubtleBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                            <TextBlock Text="{x:Static app:AiPersona.Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="{DynamicResource ThemeFontSizeMd}"
                                                       VerticalAlignment="Center"/>

                                            <!-- Display mode selector -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2"
                                                        VerticalAlignment="Center" Margin="0,0,6,0">
                                                <!-- Full height -->
                                                <Button Command="{Binding SetAiTrayDisplayModeCommand}"
                                                        CommandParameter="{x:Static models:AiTrayDisplayMode.AttachedFull}"
                                                        ToolTip.Tip="Full height"
                                                        Background="Transparent" BorderThickness="0"
                                                        Padding="4" MinWidth="24" MinHeight="24"
                                                        Cursor="Hand"
                                                        Classes.active="{Binding IsAiTrayAttachedFull}">
                                                    <Button.Styles>
                                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                            <Setter Property="Background" Value="{DynamicResource ThemeSecondaryBrush}"/>
                                                        </Style>
                                                        <Style Selector="Button.active /template/ ContentPresenter">
                                                            <Setter Property="Background" Value="{DynamicResource ThemePrimaryBrush}"/>
                                                            <Setter Property="Opacity" Value="0.2"/>
                                                        </Style>
                                                        <Style Selector="Button.active PathIcon">
                                                            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryBrush}"/>
                                                        </Style>
                                                    </Button.Styles>
                                                    <PathIcon Data="M3,2 L13,2 L13,18 L3,18 Z"
                                                              Width="12" Height="12"
                                                              Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                                </Button>
                                                <!-- Half height -->
                                                <Button Command="{Binding SetAiTrayDisplayModeCommand}"
                                                        CommandParameter="{x:Static models:AiTrayDisplayMode.AttachedHalf}"
                                                        ToolTip.Tip="Half height"
                                                        Background="Transparent" BorderThickness="0"
                                                        Padding="4" MinWidth="24" MinHeight="24"
                                                        Cursor="Hand"
                                                        Classes.active="{Binding IsAiTrayAttachedHalf}">
                                                    <Button.Styles>
                                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                            <Setter Property="Background" Value="{DynamicResource ThemeSecondaryBrush}"/>
                                                        </Style>
                                                        <Style Selector="Button.active /template/ ContentPresenter">
                                                            <Setter Property="Background" Value="{DynamicResource ThemePrimaryBrush}"/>
                                                            <Setter Property="Opacity" Value="0.2"/>
                                                        </Style>
                                                        <Style Selector="Button.active PathIcon">
                                                            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryBrush}"/>
                                                        </Style>
                                                    </Button.Styles>
                                                    <PathIcon Data="M3,10 L13,10 L13,18 L3,18 Z"
                                                              Width="12" Height="12"
                                                              Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                                </Button>
                                                <!-- Detach / Float -->
                                                <Button Command="{Binding SetAiTrayDisplayModeCommand}"
                                                        CommandParameter="{x:Static models:AiTrayDisplayMode.Detached}"
                                                        ToolTip.Tip="Floating window"
                                                        Background="Transparent" BorderThickness="0"
                                                        Padding="4" MinWidth="24" MinHeight="24"
                                                        Cursor="Hand"
                                                        Classes.active="{Binding IsAiTrayDetached}">
                                                    <Button.Styles>
                                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                            <Setter Property="Background" Value="{DynamicResource ThemeSecondaryBrush}"/>
                                                        </Style>
                                                        <Style Selector="Button.active /template/ ContentPresenter">
                                                            <Setter Property="Background" Value="{DynamicResource ThemePrimaryBrush}"/>
                                                            <Setter Property="Opacity" Value="0.2"/>
                                                        </Style>
                                                        <Style Selector="Button.active PathIcon">
                                                            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryBrush}"/>
                                                        </Style>
                                                    </Button.Styles>
                                                    <PathIcon Data="M5,3 L5,7 L1,7 L1,15 L9,15 L9,11 L13,11 L13,3 Z M3,9 L7,9 L7,13 L3,13 Z"
                                                              Width="12" Height="12"
                                                              Foreground="{DynamicResource ThemeTextMutedBrush}"/>
                                                </Button>
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                                    Content="Clear All"
                                                    Command="{Binding AiTrayVM.ClearAllCommand}"
                                                    IsVisible="{Binding AiTrayVM.HasCards}"
                                                    Background="Transparent"
                                                    Foreground="{DynamicResource ThemeTextMutedBrush}"
                                                    FontSize="{DynamicResource ThemeFontSizeXs}"
                                                    Padding="8,4" Margin="0,0,4,0"
                                                    VerticalAlignment="Center"/>
                                            <Button Grid.Column="3"
                                                    Content="x"
                                                    Command="{Binding ToggleAiTrayCommand}"
                                                    Background="{DynamicResource ThemeSecondaryBrush}"
                                                    Foreground="{DynamicResource ThemeTextBrush}"
                                                    FontSize="{DynamicResource ThemeFontSizeMd}"
                                                    FontWeight="Bold"
                                                    CornerRadius="{DynamicResource ThemeRadiusSm}"
                                                    Padding="8,4"
                                                    MinWidth="28" MinHeight="28"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Cursor="Hand"/>
                                        </Grid>
                                    </Border>
                                    <views:AiSuggestionTray x:Name="AiSuggestionTrayControl"
                                                            Grid.Row="1"
                                                            DataContext="{Binding AiTrayVM}"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Click-outside backdrop: closes InfoPanel when clicking outside -->
                        <Border x:Name="InfoPanelBackdrop"
                                Background="Transparent"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                ZIndex="9"
                                IsVisible="{Binding InfoPanelVM.IsOpen}"
                                IsHitTestVisible="{Binding InfoPanelVM.IsOpen}"
                                PointerPressed="OnInfoPanelBackdropPressed"/>

                        <!-- Info Panel: Slide Drawer (hidden on Graph/Nexus, animates in/out otherwise) -->
                        <StackPanel x:Name="InfoPanelDrawer"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Stretch"
                                    Margin="0,152,0,48"
                                    ZIndex="10"
                                    IsVisible="{Binding IsInfoPanelAvailable}"
                                    Classes.open="{Binding InfoPanelVM.IsOpen}">

                            <!-- Drag handle (grip indicator) -->
                            <Border x:Name="InfoPanelDragHandle"
                                    Width="10"
                                    Cursor="SizeWestEast"
                                    Background="Transparent"
                                    Margin="-3,0,-3,0"
                                    ZIndex="5">
                                <Border Width="4" Height="40"
                                        CornerRadius="2"
                                        Background="{DynamicResource ThemeBorderBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Opacity="0.5">
                                    <Border.Styles>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="Opacity" Value="0.9"/>
                                        </Style>
                                    </Border.Styles>
                                </Border>
                            </Border>

                            <!-- Floating panel card: rounded left, flush right -->
                            <Border CornerRadius="8,0,0,8"
                                    Background="{DynamicResource ThemeSurfaceBrush}"
                                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                                    BorderThickness="1,1,0,1"
                                    BoxShadow="-4 0 20 0 #40000000"
                                    Width="{Binding InfoPanelVM.PanelWidth}"
                                    ClipToBounds="True">
                                <views:InfoPanel DataContext="{Binding InfoPanelVM}"/>
                            </Border>
                        </StackPanel>
                </Panel>
            </Grid>
        </DockPanel>

        <!-- AI Persona Speech Balloon (dynamically positioned above AI star icon) -->
        <Border x:Name="AiBalloon"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,120,48" ZIndex="998"
                IsHitTestVisible="{Binding AiTrayVM.HasBalloonMessage}"
                Classes.balloon-visible="{Binding AiTrayVM.HasBalloonMessage}">
            <Button Command="{Binding ToggleAiTrayCommand}"
                    Background="Transparent" BorderThickness="0" Padding="0"
                    Cursor="Hand" MinHeight="0" MinWidth="0">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </Button.Styles>
                <StackPanel>
                    <!-- Balloon body -->
                    <Border Background="{DynamicResource ThemeSurfaceElevatedBrush}"
                            BorderBrush="{DynamicResource ThemePrimaryBrush}"
                            BorderThickness="1.5" CornerRadius="12"
                            Padding="14,10" BoxShadow="{DynamicResource ThemeShadowLg}"
                            MaxWidth="320">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{x:Static app:AiPersona.Name}" FontWeight="Bold"
                                       FontSize="{DynamicResource ThemeFontSizeXsSm}"
                                       Foreground="{DynamicResource ThemePrimaryBrush}"/>
                            <TextBlock Text="{Binding AiTrayVM.BalloonMessage}" TextWrapping="Wrap"
                                       FontSize="{DynamicResource ThemeFontSizeSmMd}"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <!-- Triangle tail pointing down toward star (open path — no top-edge stroke) -->
                    <Path Data="M0,0 L8,8 L16,0"
                          Fill="{DynamicResource ThemeSurfaceElevatedBrush}"
                          Stroke="{DynamicResource ThemePrimaryBrush}"
                          StrokeThickness="1.5"
                          HorizontalAlignment="Right" Margin="0,-1.5,24,0"/>
                </StackPanel>
            </Button>
        </Border>

        <!-- Toast container moved into content area panel for plugin-centered alignment -->

        <!-- ============================================== -->
        <!-- FLOATING OVERLAYS - Outside main Grid layout  -->
        <!-- ============================================== -->

        <!-- Click-outside overlay to close menus/panels -->
        <Border IsVisible="{Binding IsUserMenuOpen}"
                ZIndex="999"
                Background="Transparent"
                PointerPressed="OnOverlayPointerPressed"/>

        <!-- User Dropdown Menu (positioned near bottom-left when sidebar is expanded) -->
        <Border IsVisible="{Binding IsUserMenuOpen}"
                ZIndex="999"
                Background="{DynamicResource ThemeSurfaceBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="4"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="64,0,0,60"
                MinWidth="200"
                BoxShadow="{DynamicResource ThemeShadowLg}">
            <StackPanel>
                <!-- User Info Header -->
                <Border Padding="12,8">
                    <TextBlock Text="{Binding UserDisplayName}"
                               FontWeight="SemiBold" FontSize="{DynamicResource ThemeFontSizeSmMd}"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Transparent backdrop to close panels on click-outside -->
        <Border HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                ZIndex="999"
                IsVisible="{Binding IsAnyOverlayPanelOpen}"
                Background="Transparent"
                PointerPressed="OnBackdropPointerPressed"/>

        <!-- Sync Panel Overlay (anchored to sidebar, docked to bottom) -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Width="520" MaxHeight="900"
                ZIndex="1000"
                IsVisible="{Binding IsSyncPanelOpen}"
                Background="{DynamicResource ThemeSurfaceBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="1"
                CornerRadius="0,8,0,0"
                Margin="{Binding PanelLeftMargin}"
                BoxShadow="4 0 16 0 #30000000">
            <Grid RowDefinitions="Auto,*">
                <!-- Header -->
                <Border Grid.Row="0" Padding="16,12"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Sync" FontSize="{DynamicResource ThemeFontSizeLg}" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="×"
                                Command="{Binding ToggleSyncPanelCommand}"
                                Background="Transparent"
                                FontSize="{DynamicResource ThemeFontSizeXl}"
                                Padding="8,2"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <views:SyncPanel Grid.Row="1" DataContext="{Binding SyncVM}"/>
            </Grid>
        </Border>

        <!-- Settings Panel Overlay (anchored to sidebar, docked to bottom) -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Stretch"
                Width="520"
                ZIndex="1000"
                IsVisible="{Binding IsSettingsPanelOpen}"
                Background="{DynamicResource ThemeSurfaceBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="1"
                CornerRadius="0,8,8,0"
                Margin="{Binding PanelLeftMargin}"
                BoxShadow="4 0 16 0 #30000000">
            <Grid RowDefinitions="Auto,*">
                <!-- Header with Close button -->
                <Border Grid.Row="0" Padding="16,12"
                        BorderBrush="{DynamicResource ThemeBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Settings" FontSize="{DynamicResource ThemeFontSizeLg}" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="×"
                                Command="{Binding CloseSettingsCommand}"
                                Background="Transparent"
                                FontSize="{DynamicResource ThemeFontSizeXl}"
                                Padding="8,2"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <!-- Settings Content -->
                <views:SettingsPanel Grid.Row="1" DataContext="{Binding SettingsVM}"/>
            </Grid>
        </Border>

        <!-- GitHub Device Flow Dialog Overlay -->
        <views:GitHubDeviceFlowDialog DataContext="{Binding SettingsVM.Connections}" ZIndex="1001"/>

        <!-- Manage Plugins Dialog Overlay -->
        <views:ManagePluginsDialog DataContext="{Binding SettingsVM}" ZIndex="1001"/>

        <!-- Theme Editor Dialog Overlay -->
        <views:ThemeEditorDialog DataContext="{Binding SettingsVM.ThemeEditor}" ZIndex="1001"/>

        <!-- Property Template Manager Dialog Overlay -->
        <views:PropertyTemplateDialog DataContext="{Binding InfoPanelVM.TemplateDialog}" ZIndex="1001"/>

        <!-- AI Suggestion Tray — removed; now rendered as slide drawer inside content area -->

        <!-- Intent Slot Editor Overlay -->
        <views:IntentSlotEditorOverlay DataContext="{Binding IntentSlotEditorVM}" ZIndex="1001"/>

        <!-- Universal Search Dropdown (anchored below toolbar search pill) -->
        <controls:UniversalSearchDropdown x:Name="SearchDropdown"
            DataContext="{Binding CommandPaletteVM}"
            ZIndex="1001"
            IsVisible="{Binding IsOpen}"/>

        <!-- Unified Emoji Picker Overlay -->
        <emoji:EmojiPicker DataContext="{Binding EmojiPickerVM}" ZIndex="1001"/>

        <!-- Speech Recording Overlay -->
        <views:SpeechRecordingOverlay DataContext="{Binding SpeechRecordingVM}" ZIndex="1001"/>

        <!-- Update Modal -->
        <views:UpdateModal DataContext="{Binding UpdateVM}" ZIndex="1001"/>

        <!-- Subscription Detail Modal -->
        <views:SubscriptionDetailModal DataContext="{Binding SubscriptionBadgeVM}" ZIndex="1001"/>

        <!-- Quick Action Overlay (modal backdrop + content) -->
        <Border IsVisible="{Binding IsQuickActionOverlayOpen}"
                ZIndex="1002"
                Background="#80000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                PointerPressed="OnQuickActionBackdropPressed">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="400" MaxWidth="520"
                    Background="{DynamicResource ThemeSurfaceBrush}"
                    BorderBrush="{DynamicResource ThemeBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource ThemeRadiusMd}"
                    BoxShadow="{DynamicResource ThemeShadowXl}"
                    Padding="0"
                    IsHitTestVisible="True"
                    PointerPressed="OnQuickActionContentPressed">
                <Grid RowDefinitions="Auto,*">
                    <!-- Header -->
                    <Border Grid.Row="0" Padding="20,16"
                            BorderBrush="{DynamicResource ThemeBorderSubtleBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding QuickActionOverlayTitle}"
                                       FontWeight="SemiBold"
                                       FontSize="{DynamicResource ThemeFontSizeMd}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="×"
                                    Command="{Binding CloseQuickActionOverlayCommand}"
                                    Background="Transparent"
                                    FontSize="{DynamicResource ThemeFontSizeXl}"
                                    Padding="8,2"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <!-- Dynamic content from the quick action provider -->
                    <ContentPresenter Grid.Row="1" Content="{Binding QuickActionOverlayContent}"
                                      Margin="20,16,20,20"/>
                </Grid>
            </Border>
        </Border>

        <!-- Workspace Switcher Overlay -->
        <views:WorkspaceSwitcherOverlay DataContext="{Binding WorkspaceSwitcherVM}" ZIndex="1002"/>

    </Panel>
</Window>
